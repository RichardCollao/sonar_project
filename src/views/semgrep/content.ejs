          <label class="form-check-label" for="cfg-docker">p/docker</label>
        </div>
        <div class="form-check">
          <input class="form-check-input semgrep-config-flag" type="checkbox" id="cfg-kubernetes" value="p/kubernetes">
          <label class="form-check-label" for="cfg-kubernetes">p/kubernetes</label>
        </div>
        <div class="form-check">
          <input class="form-check-input semgrep-config-flag" type="checkbox" id="cfg-terraform" value="p/terraform">
          <label class="form-check-label" for="cfg-terraform">p/terraform</label>
        </div>
        <div class="form-check">
          <input class="form-check-input semgrep-config-flag" type="checkbox" id="cfg-cloud" value="p/cloud">
