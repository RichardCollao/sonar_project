        <div class="form-check">
          <input class="form-check-input semgrep-config-flag" type="checkbox" id="cfg-secrets" value="p/secrets">
          <label class="form-check-label" for="cfg-secrets">p/secrets</label>
        </div>
        <div class="form-check">
          <input class="form-check-input semgrep-config-flag" type="checkbox" id="cfg-owasp" value="p/owasp-top-ten">
          <label class="form-check-label" for="cfg-owasp">p/owasp-top-ten</label>
        </div>
        <div class="form-check">
          <input class="form-check-input semgrep-config-flag" type="checkbox" id="cfg-ci" value="p/ci">
          <label class="form-check-label" for="cfg-ci">p/ci</label>
        </div>
      </div>

      <div class="col-md-2">
        <div class="fw-semibold mb-1">Por tipo de vulnerabilidad</div>
        <div class="form-check">
          <input class="form-check-input semgrep-config-flag" type="checkbox" id="cfg-xss" value="p/xss">
          <label class="form-check-label" for="cfg-xss">p/xss</label>
        </div>
        <div class="form-check">
          <input class="form-check-input semgrep-config-flag" type="checkbox" id="cfg-sql-injection"
            value="p/sql-injection">
          <label class="form-check-label" for="cfg-sql-injection">p/sql-injection</label>
        </div>
        <div class="form-check">
          <input class="form-check-input semgrep-config-flag" type="checkbox" id="cfg-jwt" value="p/jwt">
          <label class="form-check-label" for="cfg-jwt">p/jwt</label>
        </div>
        <div class="form-check">
          <input class="form-check-input semgrep-config-flag" type="checkbox" id="cfg-command-injection"
            value="p/command-injection">
          <label class="form-check-label" for="cfg-command-injection">p/command-injection</label>
        </div>
        <div class="form-check">
          <input class="form-check-input semgrep-config-flag" type="checkbox" id="cfg-path-traversal"
            value="p/path-traversal">
          <label class="form-check-label" for="cfg-path-traversal">p/path-traversal</label>
        </div>
        <div class="form-check">
          <input class="form-check-input semgrep-config-flag" type="checkbox" id="cfg-crypto" value="p/crypto">
          <label class="form-check-label" for="cfg-crypto">p/crypto</label>
        </div>
        <div class="form-check">
          <input class="form-check-input semgrep-config-flag" type="checkbox" id="cfg-auth" value="p/auth">
          <label class="form-check-label" for="cfg-auth">p/auth</label>
        </div>
        <div class="form-check">
          <input class="form-check-input semgrep-config-flag" type="checkbox" id="cfg-cors" value="p/cors">
          <label class="form-check-label" for="cfg-cors">p/cors</label>
        </div>
      </div>

      <div class="col-md-2">
        <div class="fw-semibold mb-1">JavaScript / TypeScript</div>
        <div class="form-check">
          <input class="form-check-input semgrep-config-flag" type="checkbox" id="cfg-javascript" value="p/javascript">
          <label class="form-check-label" for="cfg-javascript">p/javascript</label>
        </div>
        <div class="form-check">
          <input class="form-check-input semgrep-config-flag" type="checkbox" id="cfg-typescript" value="p/typescript">
          <label class="form-check-label" for="cfg-typescript">p/typescript</label>
        </div>
        <div class="form-check">
          <input class="form-check-input semgrep-config-flag" type="checkbox" id="cfg-nodejs" value="p/nodejs">
          <label class="form-check-label" for="cfg-nodejs">p/nodejs</label>
        </div>
        <div class="form-check">
          <input class="form-check-input semgrep-config-flag" type="checkbox" id="cfg-react" value="p/react">
          <label class="form-check-label" for="cfg-react">p/react</label>
        </div>

        <div class="fw-semibold mb-1 mt-2">Python</div>
        <div class="form-check">
          <input class="form-check-input semgrep-config-flag" type="checkbox" id="cfg-python" value="p/python">
          <label class="form-check-label" for="cfg-python">p/python</label>
        </div>
        <div class="form-check">
          <input class="form-check-input semgrep-config-flag" type="checkbox" id="cfg-django" value="p/django">
          <label class="form-check-label" for="cfg-django">p/django</label>
        </div>
        <div class="form-check">
          <input class="form-check-input semgrep-config-flag" type="checkbox" id="cfg-flask" value="p/flask">
          <label class="form-check-label" for="cfg-flask">p/flask</label>
        </div>
      </div>

      <div class="col-md-2">
        <div class="fw-semibold mb-1">Java</div>
        <div class="form-check">
          <input class="form-check-input semgrep-config-flag" type="checkbox" id="cfg-java" value="p/java">
          <label class="form-check-label" for="cfg-java">p/java</label>
        </div>
        <div class="form-check">
          <input class="form-check-input semgrep-config-flag" type="checkbox" id="cfg-spring" value="p/spring">
          <label class="form-check-label" for="cfg-spring">p/spring</label>
        </div>

        <div class="fw-semibold mb-1 mt-2">C#</div>
        <div class="form-check">
          <input class="form-check-input semgrep-config-flag" type="checkbox" id="cfg-csharp" value="p/csharp">
