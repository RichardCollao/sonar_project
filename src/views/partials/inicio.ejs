<!-- Tab: Inicio -->
<div class="tab-pane fade show active" id="home-tab-pane" role="tabpanel" aria-labelledby="home-tab">
  <div class="row mt-3">
    <h3><i class="bi bi-cloud-check"></i> Proyectos</h3>
    <hr>
    <div class="col-md-4">
      <select id="selProject" class="form-select form-select-sm" aria-label="Default select example">
        <option value="" selected disabled>Seleccionar proyecto</option>
      </select>
    </div>
    <div class="col-md-8">
      <button type="button" id="btnOpenSonar" class="btn btn-sm btn-outline-secondary" onclick="openSonarProject()"
        disabled>
        <i class="bi bi-box-arrow-up-right me-2"></i>SonarQube
      </button>
      <button type="button" id="btnDiff" class="btn btn-sm btn-outline-secondary ms-2" onclick="openDiffModal()">
        <i class="bi bi-card-list me-2"></i>diff
      </button>
    </div>
  </div>
  <hr>

  <div class="row mt-3">

    <div class="col-md-6">
      <div class="d-flex justify-content-between align-items-center mb-1">
        <label for="txtSources" class="form-label mb-0">SOURCES</label>
      </div>
      <textarea class="form-control" id="txtSources" rows="8"></textarea>
    </div>

    <div class="col-md-6">
      <label for="txtExclusions" class="form-label">EXCLUSIONS</label>
      <textarea class="form-control" id="txtExclusions" rows="8"></textarea>
    </div>
  </div>
  <hr>
  <div class="row mt-3">
    <div class="col-md-4">
      <i class="bi bi-terminal"></i> Consola SonarScanner
    </div>
    <div class="col-md-8 text-end">
      <button type="button" id="btnScanner" class="btn btn-sm btn-outline-secondary">
        <i class="bi bi-terminal me-2"></i>SonarScanner
      </button>
      <button type="button" id="btnClearScannerConsole" class="btn btn-sm btn-outline-secondary">
        <i class="bi bi-eraser me-1"></i>Limpiar
      </button>
    </div>
  </div>

  <div class="row mt-3">
    <div class="col-md-12">
      <div id="scannerTerminal" class="scanner-terminal"></div>
    </div>
  </div>
</div>

<%- include('diffBranchesModal') %>

  <style>
    input[readonly] {
      user-select: none;
    }
  </style>

  <script>
    function updateOpenSonarButtonState() {
      const select = document.querySelector('#selProject');
      const button = document.querySelector('#btnOpenSonar');
      if (!button) return;

      button.disabled = !(select && select.value);
    }

    function openSonarProject() {
      const select = document.querySelector('#selProject');

      const projectKey = (select?.value || '').trim();
      const hostUrl = String(window.globalSonarHostUrl || '').trim().replace(/\/$/, '');

      if (!projectKey) {
        if (typeof Swal !== 'undefined') {
          Swal.fire({ icon: 'warning', title: 'Proyecto requerido', text: 'Selecciona un proyecto.' });
        }
        return;
      }

      if (!hostUrl) {
        if (typeof Swal !== 'undefined') {
          Swal.fire({ icon: 'warning', title: 'URL requerida', text: 'Configura primero globalSonarHostUrl en el archivo .env.' });
        }
        return;
      }

      const sonarUrl = `${hostUrl}/dashboard?id=${encodeURIComponent(projectKey)}`;
      window.open(sonarUrl, '_blank', 'noopener,noreferrer');
    }

    function poblarSelect(arr) {
      const projects = Array.isArray(arr) ? arr : [];
      const select = document.querySelector('#selProject');
      if (!select) return;

      const options = ['<option value="" selected disabled>Seleccionar proyecto</option>']
        .concat(projects.map(obj => `<option value="${obj.sonarProjectKey || ''}">${obj.sonarProjectKey || ''}</option>`));

      select.innerHTML = options.join('\n');
      select.disabled = projects.length === 0;
      updateOpenSonarButtonState();
    }

    document.addEventListener('DOMContentLoaded', function () {
      const select = document.querySelector('#selProject');
      if (select) {
        select.addEventListener('change', updateOpenSonarButtonState);
      }
      updateOpenSonarButtonState();
    });

  </script>