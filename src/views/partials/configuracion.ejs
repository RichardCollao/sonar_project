<!-- Tab: Configuración -->
<div class="tab-pane fade" id="config-tab-pane" role="tabpanel" aria-labelledby="config-tab">
    <div class="mt-3 p-3">
        <h3><i class="bi bi-gear"></i> Configuración</h3>
        <hr>
        <form id="frmGlobalConfig" class="row g-3">
            <div class="col-12 col-md-4">
                <label for="globalSonarToken" class="form-label">sonarToken</label>
                <input type="text" class="form-control form-control-sm" id="globalSonarToken" required>
            </div>
            <div class="col-12 col-md-3">
                <label for="globalSonarWorkingDirectory" class="form-label">sonarWorkingDirectory</label>
                <div class="input-group input-group-sm mb-3">
                    <span class="input-group-text">/workspace/</span>
                    <input type="text" class="form-control form-control-sm" id="globalSonarWorkingDirectory" value="sonar/working_directory" required>
                    <button type="button" class="btn btn-outline-secondary" onclick="openGlobalFileExplorerModal('globalSonarWorkingDirectory')"><i class="bi bi-folder2-open"></i></button>
                </div>
            </div>
            <div class="col-12 col-md-3">
                <label for="globalConfigDirectory" class="form-label">configDirectory</label>
                <div class="input-group input-group-sm mb-3">
                    <span class="input-group-text">/workspace/</span>
                    <input type="text" class="form-control form-control-sm" id="globalConfigDirectory" value="sonar/config_directory" required>
                    <button type="button" class="btn btn-outline-secondary" onclick="openGlobalFileExplorerModal('globalConfigDirectory')"><i class="bi bi-folder2-open"></i></button>
                </div>
            </div>

            <div class="col-12 col-md-1">
                <label for="btnSaveGlobalConfig" class="form-label">&nbsp;</label>
                <button type="button" id="btnSaveGlobalConfig" class="btn btn-sm btn-outline-secondary form-control"
                    onclick="saveGlobalConfig()">
                    <i class="bi bi-floppy me-1"></i>Guardar</button>
            </div>
        </form>
        <hr>
        <div class="mt-3 d-flex">
            <button id="btnNewProject" class="btn btn-sm btn-outline-secondary" type="button"
                onclick="openNewProjectModal()">
                <i class="bi bi-journal-plus me-1"></i>Crear proyecto
            </button>
        </div>
    </div>

    <div class="table-responsive">
        <table id="tblProjects" class="table table-sm table-striped table-bordered table-hover align-middle w-100">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Project Key</th>
                    <th>Project Base Dir</th>
                    <th>Acciones</th>
                </tr>
            </thead>
            <tbody></tbody>
        </table>
    </div>

    <%- include('newProjectModal') %>
        <%- include('editProjectModal') %>
            <%- include('fileExplorerModal') %>

</div>

<script>
    document.addEventListener('DOMContentLoaded', function () {
        loadGlobalConfig();
    });


    // Renderiza la tabla de proyectos con DataTables usando la lista recibida.
    function poblarTabla(rows = []) {
        if (typeof $ === 'undefined' || !$.fn?.dataTable) return;
        if (!document.getElementById('tblProjects')) return;

        ($.fn.dataTable.isDataTable('#tblProjects')) && $('#tblProjects').DataTable().clear().destroy();

        const dataSet = [];

        rows.forEach(function (row, index) {
            const fileName = row.fileName || '';

            dataSet.push([
                String(index + 1),
                row.sonarProjectKey || '',
                row.sonarProjectBaseDir ? `/workspace/${row.sonarProjectBaseDir}` : '',
                `<div class="text-center d-flex justify-content-center gap-1">
                    <button type="button" class="btn btn-outline-primary btn-sm btn-edit-project" data-file-name="${fileName}" data-project-key="${encodeURIComponent(row.sonarProjectKey || '')}" data-project-base-dir="${encodeURIComponent(row.sonarProjectBaseDir || '')}" title="Editar" onclick="editProject(this)"><i class="bi bi-pencil-square"></i></button>
                    <button type="button" class="btn btn-outline-danger btn-sm btn-delete-project" data-file-name="${fileName}" title="Eliminar" onclick="deleteProject(this)"><i class="bi bi-trash3"></i></button>
                </div>`
            ]);
        });

        $('#tblProjects').DataTable({
            data: dataSet,
            paging: true,
            ordering: true,
            info: true,
            searching: true,
            lengthChange: true,
            order: [],
            pageLength: 10,
        });

        $('#tblProjects').css('max-width', '99.9%');
    }

    async function editProject(button) {
        const fileName = button?.dataset?.fileName || '';
        if (!fileName) return;

        const currentProjectKey = decodeURIComponent(button?.dataset?.projectKey || '');
        const currentProjectBaseDir = decodeURIComponent(button?.dataset?.projectBaseDir || '');

        if (typeof openEditProjectModal === 'function') {
            openEditProjectModal(fileName, currentProjectKey, currentProjectBaseDir);
        }
    }

    // Carga la configuración global y la pinta en el formulario.
    function loadGlobalConfig() {
        request('/api/projects/global', 'GET', null, function (response) {
            const data = response?.data || {};
            const tokenInput = document.getElementById('globalSonarToken');
            const workingDirInput = document.getElementById('globalSonarWorkingDirectory');

            if (tokenInput) tokenInput.value = data.sonarToken || '';
            if (workingDirInput && data.sonarWorkingDirectory) workingDirInput.value = data.sonarWorkingDirectory;
            window.globalSonarHostUrl = data.sonarHostUrl || '';
        });
    }

    // Guarda configuración global (onclick desde HTML)
    function saveGlobalConfig() {
        const globalConfigForm = document.getElementById('frmGlobalConfig');
        if (!globalConfigForm?.reportValidity()) return;

        const payload = {
            sonarToken: document.getElementById('globalSonarToken').value.trim() || '',
            sonarWorkingDirectory: document.getElementById('globalSonarWorkingDirectory').value.trim() || ''
        };

        request('/api/projects/global', 'POST', payload, function (json) {
            loadGlobalConfig();
            if (json && json.warning) {
                Swal.fire({
                    icon: 'warning',
                    title: 'Configuración guardada con advertencia',
                    text: json.warning,
                    confirmButtonText: 'Entendido'
                });
            } else {
                Swal.fire({
                    icon: 'success',
                    title: 'Configuración guardada',
                    text: 'La configuración global se guardó correctamente.',
                    timer: 3000,
                    timerProgressBar: true,
                    showConfirmButton: false
                });
            }
        });
    }

    // Elimina proyecto (onclick desde HTML)
    async function deleteProject(button) {
        const fileName = button.dataset.fileName;
        if (!fileName) return;

        const result = await Swal.fire({
            title: '¿Eliminar proyecto?',
            text: 'Esta acción no se puede deshacer.',
            icon: 'warning',
            showCancelButton: true,
            confirmButtonText: 'Sí, eliminar',
            cancelButtonText: 'Cancelar',
            confirmButtonColor: '#dc3545'
        });

        if (!result.isConfirmed) return;

        request(`/api/projects/${encodeURIComponent(fileName)}`, 'DELETE', null, function (response) {
            if (typeof loadProjects === 'function') {
                setTimeout(loadProjects, 100);
            }

            if (typeof iziToastSuccess === 'function') {
                const successMessage = response?.message || 'Proyecto eliminado correctamente.';
                iziToastSuccess(successMessage);
            }
        });
    }


</script>