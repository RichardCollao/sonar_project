<div class="row mt-3">
    <div class="d-flex justify-content-between align-items-center mb-2">
        <h3 class="mb-0"><i class="bi bi-gear"></i> Configuración Sonar</h3>
    </div>
    <hr>
    <div class="col-12">
        <div class="card">
            <div class="card-header d-flex align-items-center gap-2">
                <i class="bi bi-key"></i>
                <span class="fw-semibold">Credenciales</span>
            </div>
            <div class="card-body">
                <form id="frmGlobalConfig" class="row g-3">
                    <div class="col-12 col-md-6 col-lg-4">
                        <label for="globalSonarToken" class="form-label">sonarToken</label>
                        <input type="text" class="form-control form-control-sm" id="globalSonarToken" required>
                    </div>
                    <div class="col-12 col-md-2 col-lg-2">
                        <label for="btnSaveGlobalConfig" class="form-label">&nbsp;</label>
                        <button type="button" id="btnSaveGlobalConfig"
                            class="btn btn-sm btn-outline-secondary form-control" onclick="saveGlobalConfig()">
                            <i class="bi bi-floppy me-1"></i>Guardar
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', function () {
        loadGlobalConfig();
    });

    function loadGlobalConfig() {
        request('/api/sonar/global', 'GET', null, function (response) {
            const data = response?.data || {};
            document.getElementById('globalSonarToken').value = data.sonarToken || '';
            globalThis.globalSonarHostUrl = data.sonarHostUrl;
        });
    }

    function saveGlobalConfig() {
        const globalConfigForm = document.getElementById('frmGlobalConfig');
        if (!globalConfigForm?.reportValidity()) return;

        const payload = {
            sonarToken: document.getElementById('globalSonarToken').value.trim() || ''
        };

        request('/api/sonar/global', 'POST', payload, function (json) {
            loadGlobalConfig();
            if (json && json.warning) {
                Swal.fire({
                    icon: 'warning',
                    title: 'Configuración guardada con advertencia',
                    text: json.warning,
                    confirmButtonText: 'Entendido'
                });
            } else {
                Swal.fire({
                    icon: 'success',
                    title: 'Configuración guardada',
                    text: 'La configuración de Sonar se guardó correctamente.',
                    timer: 3000,
                    timerProgressBar: true,
                    showConfirmButton: false
                });
            }
        });
    }
</script>