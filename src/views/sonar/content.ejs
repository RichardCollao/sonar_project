<!-- Sonar -->
<div class="row mt-3">
    <div class="d-flex justify-content-between align-items-center mb-2">
      <h3 class="mb-0"><i class="bi bi-cloud-check"></i> Sonar</h3>
      <a href="/sonar_config" class="btn btn-sm btn-outline-secondary">
        <i class="bi bi-gear me-1"></i>Configuración
      </a>
    </div>
    <hr>
    <div class="col-md-4">
      <select id="selProject" class="form-select form-select-sm" aria-label="Default select example">
        <option value="" selected disabled>Seleccionar proyecto</option>
      </select>
    </div>
    <div class="col-md-8">
      <button type="button" id="btnOpenSonar" class="btn btn-sm btn-outline-secondary" onclick="openSonarProject()"
        disabled>
        <i class="bi bi-box-arrow-up-right me-2"></i>SonarQube
      </button>
      <button type="button" id="btnDiff" class="btn btn-sm btn-outline-secondary ms-2" onclick="openDiffModal()">
        <i class="bi bi-card-list me-2"></i>diff
      </button>
    </div>
  </div>
  <hr>

  <div class="row mt-3">

    <div class="col-md-6">
      <div class="d-flex justify-content-between align-items-center mb-1">
        <label for="txtSources" class="form-label mb-0">SOURCES</label>
      </div>
      <textarea class="form-control" id="txtSources" rows="8"></textarea>
    </div>

    <div class="col-md-6">
      <label for="txtExclusions" class="form-label">EXCLUSIONS</label>
      <textarea class="form-control" id="txtExclusions" rows="8"></textarea>
    </div>
  </div>
  <hr>
  <div class="row mt-3">
    <div class="col-md-4">
      <i class="bi bi-terminal"></i> Consola SonarScanner
    </div>
    <div class="col-md-8 text-end">
      <button type="button" id="btnDownloadSonarPdf" class="btn btn-sm btn-outline-secondary me-2" onclick="downloadSonarPdf()"
        disabled>
        <i class="bi bi-file-earmark-pdf me-2"></i>Descargar PDF
      </button>
      <button type="button" id="btnScanner" class="btn btn-sm btn-outline-secondary">
        <i class="bi bi-terminal me-2"></i>SonarScanner
      </button>
      <button type="button" id="btnClearScannerConsole" class="btn btn-sm btn-outline-secondary ms-2">
        <i class="bi bi-eraser me-1"></i>Limpiar
      </button>
    </div>
  </div>

  <div class="row mt-3">
    <div class="col-md-12">
      <div id="scannerTerminal" class="scanner-terminal">
        <div id="scannerTerminalInner" class="scanner-terminal-inner"></div>
      </div>
    </div>
  </div>
</div>

<%- include('diffBranchesModal') %>

  <style>
    input[readonly] {
      user-select: none;
    }
  </style>

  <script>
    document.addEventListener('DOMContentLoaded', function () {
      globalThis.sonarPdfReadyProjectName = '';
      const select = document.querySelector('#selProject');
      if (select) {
        select.addEventListener('change', globalThis.updateOpenSonarButtonState);
      }

      request('/api/sonar/global', 'GET', null, function(response) {
        const data = response?.data || {};
        globalThis.globalSonarHostUrl = data.sonarHostUrl || '';
      });

      globalThis.updateOpenSonarButtonState();
    });


    globalThis.updateOpenSonarButtonState = function updateOpenSonarButtonState() {
      const select = document.querySelector('#selProject');
      const button = document.querySelector('#btnOpenSonar');
      const pdfButton = document.querySelector('#btnDownloadSonarPdf');
      const scannerButton = document.querySelector('#btnScanner');
      const selectedProject = (select?.value || '').trim();
      const enabled = !!selectedProject;
      const pdfEnabled = enabled && selectedProject === String(globalThis.sonarPdfReadyProjectName || '').trim();

      if (!button) return;

      button.disabled = !enabled;

      if (pdfButton) {
        pdfButton.disabled = !pdfEnabled;
      }

      if (scannerButton) {
        scannerButton.disabled = !enabled;
      }
    }

    function openSonarProject() {
      const select = document.querySelector('#selProject');

      const projectKey = (select?.value || '').trim();
      const hostUrl = String(globalThis.globalSonarHostUrl || '').trim().replace(/\/$/, '');

      if (!projectKey) {
        if (typeof Swal !== 'undefined') {
          Swal.fire({ icon: 'warning', title: 'Nombre de proyecto requerido', text: 'Selecciona un nombre de proyecto.' });
        }
        return;
      }

      if (!hostUrl) {
        if (typeof Swal !== 'undefined') {
          Swal.fire({ icon: 'warning', title: 'URL requerida', text: 'Configura primero globalSonarHostUrl en el archivo .env.' });
        }
        return;
      }

      const sonarUrl = `${hostUrl}/dashboard?id=${encodeURIComponent(projectKey)}`;
      window.open(sonarUrl, '_blank', 'noopener,noreferrer');
    }

    async function downloadSonarPdf() {
      const select = document.querySelector('#selProject');
      const pdfButton = document.querySelector('#btnDownloadSonarPdf');
      const projectKey = (select?.value || '').trim();

      if (!projectKey) {
        if (typeof Swal !== 'undefined') {
          Swal.fire({ icon: 'warning', title: 'Nombre de proyecto requerido', text: 'Selecciona un nombre de proyecto.' });
        }
        return;
      }

      if (pdfButton) {
        pdfButton.disabled = true;
      }

      try {
        const response = await fetch(`/api/sonar/report/pdf?projectName=${encodeURIComponent(projectKey)}`, {
          method: 'GET',
          credentials: 'include'
        });

        if (!response.ok) {
          let message = 'No fue posible generar el PDF de Sonar.';

          try {
            const data = await response.json();
            message = data?.message || message;
          } catch {
          }

          throw new Error(message);
        }

        const blob = await response.blob();
        const contentDisposition = String(response.headers.get('content-disposition') || '');
        const fileNameMatch = /filename="?([^";]+)"?/i.exec(contentDisposition);
        const fileName = (fileNameMatch && fileNameMatch[1])
          ? fileNameMatch[1]
          : `sonar-report-${projectKey}.pdf`;

        const blobUrl = window.URL.createObjectURL(blob);
        const anchor = document.createElement('a');
        anchor.href = blobUrl;
        anchor.download = fileName;
        document.body.appendChild(anchor);
        anchor.click();
        anchor.remove();
        window.URL.revokeObjectURL(blobUrl);
      } catch (error) {
        if (typeof Swal !== 'undefined') {
          Swal.fire({ icon: 'error', title: 'Error', text: error?.message || 'No fue posible generar el PDF de Sonar.' });
        }
      } finally {
        globalThis.updateOpenSonarButtonState();
      }
    }

    function poblarSelect(arr) {
      const projects = Array.isArray(arr) ? arr : [];
      const select = document.querySelector('#selProject');
      if (!select) return;

      const options = ['<option value="" selected disabled>Seleccionar proyecto</option>']
        .concat(projects.map(obj => `<option value="${obj.projectName || ''}">${obj.projectName || ''}</option>`));

      select.innerHTML = options.join('\n');
      select.disabled = projects.length === 0;
      globalThis.updateOpenSonarButtonState();
    }



  </script>